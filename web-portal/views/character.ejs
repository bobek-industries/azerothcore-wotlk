<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= character.name %> - Character Details</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;800&family=IBM+Plex+Sans:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <div class="aurora"></div>
    <main class="shell reveal">
      <section class="hero card">
        <p class="kicker">Character Details</p>
        <h1><%= character.name %></h1>
        <p class="subtitle">
          Level <strong><%= character.level %></strong> <%= character.race %> <%= character.class %>
        </p>

        <div class="actions">
          <a class="btn btn-ghost" href="/panel">Back To User Panel</a>
          <% if (isAdmin) { %>
          <a class="btn btn-ghost" href="/admin">Admin Panel</a>
          <% } %>
          <form method="post" action="/logout">
            <button class="btn btn-primary" type="submit">Log Out</button>
          </form>
        </div>

        <% if (flash) { %>
        <div class="flash <%= flash.type %>"><%= flash.message %></div>
        <% } %>

        <div class="status-grid">
          <article class="status-item <%= character.online ? 'up' : 'down' %>">
            <h3>Status</h3>
            <p><%= character.online ? 'Online' : 'Offline' %></p>
            <small>GUID <%= character.guid %></small>
          </article>
          <article class="status-item up">
            <h3>Money</h3>
            <p><%= character.money %></p>
            <small>Inventory wealth</small>
          </article>
          <article class="status-item up">
            <h3>Played Time</h3>
            <p><%= character.played %></p>
            <small>Total gameplay</small>
          </article>
          <article class="status-item up">
            <h3>Location</h3>
            <p><%= character.mapName %></p>
            <small>Map <%= character.mapId %>, Zone <%= character.zoneId %></small>
          </article>
        </div>

        <section class="admin-block">
          <h2>Position</h2>
          <p>X: <strong><%= character.position.x %></strong> | Y: <strong><%= character.position.y %></strong> | Z: <strong><%= character.position.z %></strong></p>
          <small>Gender: <%= character.gender %> | Created: <%= character.createdAt %></small>
        </section>

        <section class="admin-block">
          <h2>Inventory Summary</h2>
          <div class="status-grid">
            <article class="status-item up">
              <h3>Total Items</h3>
              <p><%= character.inventorySummary.totalItemCount %></p>
              <small>All stacks combined</small>
            </article>
            <article class="status-item up">
              <h3>Unique Entries</h3>
              <p><%= character.inventorySummary.uniqueItemEntries %></p>
              <small>Different item ids</small>
            </article>
            <article class="status-item up">
              <h3>Inventory Slots Used</h3>
              <p><%= character.inventorySummary.inventorySlotsUsed %></p>
              <small>Across all bags</small>
            </article>
            <article class="status-item up">
              <h3>Equipped Slots</h3>
              <p><%= character.inventorySummary.equippedSlots %></p>
              <small>Main equipment range</small>
            </article>
          </div>
        </section>

        <section class="admin-block">
          <h2>Top Inventory Items</h2>
          <% if (character.topItems.length === 0) { %>
          <div class="empty">No inventory data for this character.</div>
          <% } else { %>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Item Entry</th>
                  <th>Name</th>
                  <th>Total Count</th>
                </tr>
              </thead>
              <tbody>
                <% character.topItems.forEach((item) => { %>
                <tr>
                  <td><%= item.itemEntry %></td>
                  <td><%= item.name %></td>
                  <td><%= item.count %></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <% } %>
        </section>
      </section>
    </main>
  </body>
</html>
