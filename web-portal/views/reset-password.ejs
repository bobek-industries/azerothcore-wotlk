<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password &mdash; Bobek Industries</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;800&family=IBM+Plex+Sans:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <div class="aurora"></div>

    <nav class="site-nav">
      <div class="nav-inner">
        <a class="nav-brand" href="/">
          Bobek Industries
          <span class="nav-sub">WotLK 3.3.5a</span>
        </a>
        <div class="nav-links">
          <a class="btn btn-ghost" href="/">Back to Portal</a>
        </div>
      </div>
    </nav>

    <main class="shell reveal">
      <section class="card">
        <p class="kicker">Bobek Industries</p>
        <h1>Choose New Password</h1>
        <p class="subtitle">Account: <strong><%= username %></strong></p>

        <% if (flash) { %>
        <div class="flash <%= flash.type %>"><%= flash.message %></div>
        <% } %>

        <div class="divider"><h2>Set Password</h2></div>

        <form class="panel" method="post" action="/reset-password/confirm">
          <input type="hidden" name="token" value="<%= token %>" />
          <label>
            New Password
            <input name="password" type="password" maxlength="16" required />
          </label>
          <label>
            Confirm Password
            <input name="passwordConfirm" type="password" maxlength="16" required />
          </label>
          <button type="submit" class="btn btn-primary">Set New Password</button>
        </form>
      </section>
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          Bobek Industries
          <span class="footer-patch">WotLK 3.3.5a</span>
        </div>
        <p class="footer-legal">Not affiliated with Blizzard Entertainment. World of Warcraft&trade; is a registered trademark of Blizzard Entertainment, Inc.</p>
      </div>
    </footer>
  </body>
</html>
