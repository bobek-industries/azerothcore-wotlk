<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Reset Password</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;800&family=IBM+Plex+Sans:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <div class="aurora"></div>
    <main class="shell reveal">
      <section class="hero card">
        <p class="kicker">Realm Portal</p>
        <h1>Choose New Password</h1>
        <p class="subtitle">Account: <strong><%= username %></strong></p>

        <% if (flash) { %>
        <div class="flash <%= flash.type %>"><%= flash.message %></div>
        <% } %>

        <form class="panel" method="post" action="/reset-password/confirm">
          <input type="hidden" name="token" value="<%= token %>" />
          <label>
            New Password
            <input name="password" type="password" maxlength="16" required />
          </label>
          <label>
            Confirm Password
            <input name="passwordConfirm" type="password" maxlength="16" required />
          </label>
          <button type="submit" class="btn btn-primary">Set New Password</button>
        </form>

        <div class="link-row">
          <a class="text-link" href="/">Back to portal</a>
        </div>
      </section>
    </main>
  </body>
</html>
