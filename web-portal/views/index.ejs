<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AzerothCore Realm Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;800&family=IBM+Plex+Sans:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <div class="aurora"></div>
    <main class="shell reveal">
      <section class="hero card">
        <p class="kicker">Realm Portal</p>
        <h1>Welcome to Azeroth</h1>
        <p class="subtitle">
          Register, log in, and track your adventurers from one clean dashboard.
        </p>

        <div class="status-grid">
          <% status.forEach((item) => { %>
          <article class="status-item <%= item.online ? 'up' : 'down' %>">
            <h3><%= item.name %></h3>
            <p><%= item.online ? 'Online' : 'Offline' %></p>
            <small><%= item.detail %></small>
          </article>
          <% }) %>
        </div>

        <% if (flash) { %>
        <div class="flash <%= flash.type %>"><%= flash.message %></div>
        <% } %>

        <% if (user) { %>
        <div class="actions">
          <a href="/panel" class="btn btn-primary">Open User Panel</a>
          <% if (user.gmlevel >= 3) { %>
          <a href="/admin" class="btn btn-ghost">Open Admin Panel</a>
          <% } %>
          <form method="post" action="/logout">
            <button class="btn btn-ghost" type="submit">Log Out</button>
          </form>
        </div>
        <% } else { %>
        <div class="actions">
          <button class="btn btn-primary" type="button" data-target="register">
            Register
          </button>
          <button class="btn btn-ghost" type="button" data-target="login">
            Login
          </button>
        </div>

        <section class="forms">
          <form id="register" class="panel" method="post" action="/register">
            <h2>Create Account</h2>
            <label>
              Username
              <input name="username" maxlength="16" required />
            </label>
            <label>
              Email
              <input name="email" type="email" maxlength="255" required />
            </label>
            <label>
              Password
              <input name="password" type="password" maxlength="16" required />
            </label>
            <button type="submit" class="btn btn-primary">Register Now</button>
          </form>

          <form id="login" class="panel hidden" method="post" action="/login">
            <h2>Account Login</h2>
            <label>
              Username
              <input name="username" maxlength="16" required />
            </label>
            <label>
              Password
              <input name="password" type="password" maxlength="16" required />
            </label>
            <button type="submit" class="btn btn-primary">Login</button>
          </form>

          <form id="reset" class="panel hidden" method="post" action="/reset-password">
            <h2>Password Reset Link</h2>
            <label>
              Username
              <input name="username" maxlength="16" required />
            </label>
            <label>
              Email
              <input name="email" type="email" maxlength="255" required />
            </label>
            <button type="submit" class="btn btn-primary">Send Reset Link</button>
          </form>
        </section>

        <div class="link-row">
          <button class="text-link" type="button" data-target="reset">
            Forgot password? Send reset link
          </button>
        </div>
        <% } %>
      </section>
    </main>

    <script>
      const buttons = document.querySelectorAll("[data-target]");
      const forms = document.querySelectorAll(".panel");

      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          forms.forEach((form) => form.classList.add("hidden"));
          document.getElementById(button.dataset.target).classList.remove("hidden");
        });
      });
    </script>
  </body>
</html>
