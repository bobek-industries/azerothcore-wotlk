<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bobek Industries &mdash; Realm Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;800&family=IBM+Plex+Sans:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <div class="aurora"></div>

    <nav class="site-nav">
      <div class="nav-inner">
        <a class="nav-brand" href="/">
          Bobek Industries
          <span class="nav-sub">WotLK 3.3.5a</span>
        </a>
        <div class="nav-links">
          <% if (discordUrl) { %>
          <a class="btn btn-ghost" href="<%= discordUrl %>" target="_blank" rel="noopener noreferrer">Discord</a>
          <% } %>
          <% if (forumUrl) { %>
          <a class="btn btn-ghost" href="<%= forumUrl %>" target="_blank" rel="noopener noreferrer">Forum</a>
          <% } %>
          <% if (downloadUrl) { %>
          <a class="btn btn-ghost" href="<%= downloadUrl %>" target="_blank" rel="noopener noreferrer">Download</a>
          <% } %>
          <% if (user) { %>
          <a class="btn btn-ghost" href="/panel">My Characters</a>
          <% if (user.gmlevel >= 3) { %>
          <a class="btn btn-ghost" href="/admin">Admin</a>
          <% } %>
          <form method="post" action="/logout">
            <button class="btn btn-danger" type="submit">Log Out</button>
          </form>
          <% } else { %>
          <button class="btn btn-ghost" type="button" data-target="login">Login</button>
          <button class="btn btn-primary" type="button" data-target="register">Create Account</button>
          <% } %>
        </div>
      </div>
    </nav>

    <main class="shell-home reveal">
      <!-- MAIN CARD: STATUS + AUTH -->
      <section class="card home-main-card">
          <div class="divider" style="margin-top:0">
              <h2>Server Status</h2>
            </div>

            <div class="status-grid">
              <% status.forEach((item) => { %>
              <article class="status-item <%= item.online ? 'up' : 'down' %>">
                <h3><%= item.name %></h3>
                <p><%= item.online ? 'Online' : 'Offline' %></p>
                <small><%= item.detail %></small>
              </article>
              <% }) %>
            </div>

            <div class="metrics-row">
              <div class="metric-chip">
                <span class="metric-value"><%= serverMetrics.uptimeFormatted || '&mdash;' %></span>
                <span class="metric-label">Uptime</span>
              </div>
              <div class="metric-chip">
                <span class="metric-value"><%= serverMetrics.maxPlayers %></span>
                <span class="metric-label">Peak Players</span>
              </div>
              <div class="metric-chip">
                <span class="metric-value"><%= serverMetrics.gmOnline %></span>
                <span class="metric-label">GMs Online</span>
              </div>
            </div>

            <div class="divider"><h2>Players Online</h2></div>

            <div class="online-stats">
              <div class="online-count">
                <span class="count-number"><%= onlineStats.total %></span>
                <span class="count-label">Online</span>
              </div>

              <div class="faction-bar-wrap">
                <div class="faction-labels">
                  <span class="faction-label alliance">
                    <span class="dot"></span>
                    Alliance &mdash; <%= onlineStats.alliance %> (<%= onlineStats.alliancePercent %>%)
                  </span>
                  <span class="faction-label horde">
                    Horde &mdash; <%= onlineStats.horde %> (<%= onlineStats.hordePercent %>%)
                    <span class="dot"></span>
                  </span>
                </div>
                <% if (onlineStats.total > 0) { %>
                <div class="faction-bar">
                  <div class="bar-alliance" style="width:<%= onlineStats.alliancePercent %>%"></div>
                  <div class="bar-horde"    style="width:<%= onlineStats.hordePercent %>%"></div>
                </div>
                <% } else { %>
                <div class="faction-bar-empty"></div>
                <% } %>
              </div>
            </div>
      </section>

      <!-- AUTH SECTION -->
      <% if (!user) { %>
      <section id="auth-section" class="card hidden">
        <% if (flash) { %>
        <div class="flash <%= flash.type %>"><%= flash.message %></div>
        <% } %>

        <div class="actions" style="margin-top:0;margin-bottom:1.2rem">
          <button class="btn btn-primary panel-tab" data-target="login">Sign In</button>
          <button class="btn btn-ghost panel-tab" data-target="register">Register</button>
        </div>

        <div class="forms" style="margin-top:0">
          <form id="login" class="panel" method="post" action="/login">
            <label>
              Username
              <input name="username" maxlength="16" required />
            </label>
            <label>
              Password
              <input name="password" type="password" maxlength="16" required />
            </label>
            <button type="submit" class="btn btn-primary btn-full">Sign In</button>
          </form>

          <form id="register" class="panel hidden" method="post" action="/register">
            <label>
              Username
              <input name="username" maxlength="16" required />
            </label>
            <label>
              Email
              <input name="email" type="email" maxlength="255" required />
            </label>
            <label>
              Password
              <input name="password" type="password" maxlength="16" required />
            </label>
            <button type="submit" class="btn btn-primary btn-full">Create Account</button>
          </form>

          <form id="reset" class="panel hidden" method="post" action="/reset-password">
            <label>
              Username
              <input name="username" maxlength="16" required />
            </label>
            <label>
              Email
              <input name="email" type="email" maxlength="255" required />
            </label>
            <button type="submit" class="btn btn-primary btn-full">Send Reset Link</button>
          </form>
        </div>

        <div class="link-row">
          <button class="text-link" type="button" data-target="reset">Forgot your password?</button>
        </div>
      </section>
      <% } %>

      <!-- NEWS + LEADERBOARD GRID -->
      <% if (latestNews.length > 0 || topPvp.length > 0) { %>
      <div class="home-grid">

        <% if (latestNews.length > 0) { %>
        <section class="card news-section">
          <div class="divider" style="margin-top:0"><h2>Latest News</h2></div>
          <% latestNews.forEach((post) => { %>
          <article class="news-post">
            <div class="news-meta">
              <time class="news-date"><%=
                new Date(post.created_at).toLocaleDateString("en-US", {
                  month: "short", day: "numeric", year: "numeric"
                })
              %></time>
              <span class="news-author">by <%= post.author %></span>
            </div>
            <h3 class="news-title"><%= post.title %></h3>
            <p class="news-body"><%= post.body %></p>
          </article>
          <% }) %>
        </section>
        <% } %>

        <% if (topPvp.length > 0) { %>
        <section class="card leaderboard-section">
          <div class="divider" style="margin-top:0"><h2>Top Honorable Kills</h2></div>
          <ol class="leaderboard-list">
            <% topPvp.forEach((player, i) => { %>
            <li class="leaderboard-row <%= i === 0 ? 'rank-1' : i === 1 ? 'rank-2' : i === 2 ? 'rank-3' : '' %>">
              <span class="rank-num"><%= i + 1 %></span>
              <div class="rank-info">
                <strong class="rank-name"><%= player.name %></strong>
                <small class="rank-detail"><%= player.race %> <%= player.class %> &bull; Lvl <%= player.level %></small>
              </div>
              <span class="rank-kills"><%= player.kills.toLocaleString() %></span>
            </li>
            <% }) %>
          </ol>
        </section>
        <% } %>

      </div>
      <% } %>

      <!-- HOW TO CONNECT -->
      <section class="card how-to-card">
        <div class="how-to-summary-text" style="margin-bottom:1.8rem">
          <span class="how-to-title">How to Connect</span>
          <span class="how-to-sub">Get started in 3 easy steps</span>
        </div>
        <div class="how-to-steps">
            <div class="how-to-step">
              <span class="step-num">1</span>
              <div class="step-content">
                <strong>Create an Account</strong>
                <p>Register on this page with your desired username, email, and password.</p>
                <% if (!user) { %>
                <button class="btn btn-primary" type="button" data-target="register">Register Now</button>
                <% } %>
              </div>
            </div>
            <div class="how-to-step">
              <span class="step-num">2</span>
              <div class="step-content">
                <strong>Download the Client</strong>
                <p>You need the World of Warcraft 3.3.5a client to play.</p>
                <% if (downloadUrl) { %>
                <a class="btn btn-ghost" href="<%= downloadUrl %>" target="_blank" rel="noopener noreferrer">Download Client</a>
                <% } else { %>
                <p><em>Contact an administrator for the download link.</em></p>
                <% } %>
              </div>
            </div>
            <div class="how-to-step">
              <span class="step-num">3</span>
              <div class="step-content">
                <strong>Set the Realmlist</strong>
                <p>Open <code>Data/enUS/realmlist.wtf</code> in your WoW folder and set:</p>
                <pre class="realmlist-pre">set realmlist <%= realmlistHost || 'your.server.address' %></pre>
                <p>Launch <code>Wow.exe</code>, log in with your portal credentials, and enter the world!</p>
              </div>
            </div>
        </div>
      </section>

    </main>

    <!-- FOOTER -->
    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          Bobek Industries
          <span class="footer-patch">WotLK 3.3.5a</span>
        </div>
        <p class="footer-legal">Not affiliated with Blizzard Entertainment. World of Warcraft&trade; is a registered trademark of Blizzard Entertainment, Inc.</p>
      </div>
    </footer>

    <script>
      const authSection = document.getElementById("auth-section");
      const allPanels   = document.querySelectorAll(".panel");
      const panelTabs   = document.querySelectorAll(".panel-tab");

      function activatePanel(targetId) {
        allPanels.forEach((f) => f.classList.add("hidden"));
        const el = document.getElementById(targetId);
        if (el) el.classList.remove("hidden");
      }

      function activatePanelTab(targetId) {
        panelTabs.forEach((t) => {
          t.classList.toggle("btn-primary", t.dataset.target === targetId);
          t.classList.toggle("btn-ghost",   t.dataset.target !== targetId);
        });
      }

      function showAuthSection(targetId) {
        if (!authSection) return;
        authSection.classList.remove("hidden");
        activatePanel(targetId);
        activatePanelTab(targetId);
        authSection.scrollIntoView({ behavior: "smooth", block: "nearest" });
      }

      panelTabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          activatePanel(tab.dataset.target);
          activatePanelTab(tab.dataset.target);
        });
      });

      document.querySelectorAll(".text-link[data-target]").forEach((btn) => {
        btn.addEventListener("click", () => activatePanel(btn.dataset.target));
      });

      document.querySelectorAll("[data-target]:not(.panel-tab):not(.text-link)").forEach((btn) => {
        btn.addEventListener("click", () => showAuthSection(btn.dataset.target));
      });

      <% if (flash && !user) { %>
      showAuthSection("login");
      <% } %>
    </script>
  </body>
</html>
