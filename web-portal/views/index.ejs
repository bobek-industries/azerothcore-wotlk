<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Bobek Industries &mdash; Realm Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;800&family=IBM+Plex+Sans:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <div class="aurora"></div>

    <nav class="site-nav">
      <div class="nav-inner">
        <a class="nav-brand" href="/">
          Bobek Industries
          <span class="nav-sub">WotLK 3.3.5a</span>
        </a>
        <div class="nav-links">
          <% if (user) { %>
          <a class="btn btn-ghost" href="/panel">My Characters</a>
          <% if (user.gmlevel >= 3) { %>
          <a class="btn btn-ghost" href="/admin">Admin</a>
          <% } %>
          <form method="post" action="/logout">
            <button class="btn btn-danger" type="submit">Log Out</button>
          </form>
          <% } else { %>
          <button class="btn btn-ghost" type="button" data-target="login">Login</button>
          <button class="btn btn-primary" type="button" data-target="register">Register</button>
          <% } %>
        </div>
      </div>
    </nav>

    <main class="shell reveal">
      <section class="card">
        <div class="realm-badge">
          <span>Wrath of the Lich King</span>
          <small>&bull; Patch 3.3.5a</small>
        </div>
        <p class="kicker">Bobek Industries</p>
        <h1>Welcome to Azeroth</h1>
        <p class="subtitle">Register an account, log in, and track your adventurers.</p>

        <div class="divider" style="margin-top:1.8rem">
          <h2>Server Status</h2>
        </div>

        <div class="status-grid">
          <% status.forEach((item) => { %>
          <article class="status-item <%= item.online ? 'up' : 'down' %>">
            <h3><%= item.name %></h3>
            <p><%= item.online ? 'Online' : 'Offline' %></p>
            <small><%= item.detail %></small>
          </article>
          <% }) %>
        </div>

        <div class="divider"><h2>Players Online</h2></div>

        <div class="online-stats">
          <div class="online-count">
            <span class="count-number"><%= onlineStats.total %></span>
            <span class="count-label">Online</span>
          </div>

          <div class="faction-bar-wrap">
            <div class="faction-labels">
              <span class="faction-label alliance">
                <span class="dot"></span>
                Alliance &mdash; <%= onlineStats.alliance %> (<%= onlineStats.alliancePercent %>%)
              </span>
              <span class="faction-label horde">
                Horde &mdash; <%= onlineStats.horde %> (<%= onlineStats.hordePercent %>%)
                <span class="dot"></span>
              </span>
            </div>
            <% if (onlineStats.total > 0) { %>
            <div class="faction-bar">
              <div class="bar-alliance" style="width:<%= onlineStats.alliancePercent %>%"></div>
              <div class="bar-horde"    style="width:<%= onlineStats.hordePercent %>%"></div>
            </div>
            <% } else { %>
            <div class="faction-bar-empty"></div>
            <% } %>
          </div>
        </div>

        <% if (flash) { %>
        <div class="flash <%= flash.type %>"><%= flash.message %></div>
        <% } %>

        <% if (user) { %>
        <div class="actions">
          <a href="/panel" class="btn btn-primary">Open Character Panel</a>
          <% if (user.gmlevel >= 3) { %>
          <a href="/admin" class="btn btn-ghost">Admin Panel</a>
          <% } %>
        </div>
        <% } else { %>
        <section class="forms">
          <form id="register" class="panel hidden" method="post" action="/register">
            <div class="divider"><h2>Create Account</h2></div>
            <label>
              Username
              <input name="username" maxlength="16" required />
            </label>
            <label>
              Email
              <input name="email" type="email" maxlength="255" required />
            </label>
            <label>
              Password
              <input name="password" type="password" maxlength="16" required />
            </label>
            <button type="submit" class="btn btn-primary">Register Now</button>
          </form>

          <form id="login" class="panel hidden" method="post" action="/login">
            <div class="divider"><h2>Account Login</h2></div>
            <label>
              Username
              <input name="username" maxlength="16" required />
            </label>
            <label>
              Password
              <input name="password" type="password" maxlength="16" required />
            </label>
            <button type="submit" class="btn btn-primary">Login</button>
          </form>

          <form id="reset" class="panel hidden" method="post" action="/reset-password">
            <div class="divider"><h2>Password Reset</h2></div>
            <label>
              Username
              <input name="username" maxlength="16" required />
            </label>
            <label>
              Email
              <input name="email" type="email" maxlength="255" required />
            </label>
            <button type="submit" class="btn btn-primary">Send Reset Link</button>
          </form>
        </section>

        <div class="link-row">
          <button class="text-link" type="button" data-target="reset">
            Forgot your password?
          </button>
        </div>
        <% } %>
      </section>
    </main>

    <script>
      const buttons = document.querySelectorAll("[data-target]");
      const forms   = document.querySelectorAll(".panel");

      buttons.forEach((btn) => {
        btn.addEventListener("click", () => {
          forms.forEach((f) => f.classList.add("hidden"));
          document.getElementById(btn.dataset.target).classList.remove("hidden");
        });
      });
    </script>
  </body>
</html>
