<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Panel &mdash; Bobek Industries</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;800&family=IBM+Plex+Sans:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <div class="aurora"></div>

    <nav class="site-nav">
      <div class="nav-inner">
        <a class="nav-brand" href="/">
          Bobek Industries
          <span class="nav-sub">WotLK 3.3.5a</span>
        </a>
        <div class="nav-links">
          <a class="btn btn-ghost" href="/panel">My Characters</a>
          <a class="btn btn-ghost" href="/">Home</a>
          <form method="post" action="/logout">
            <button class="btn btn-danger" type="submit">Log Out</button>
          </form>
        </div>
      </div>
    </nav>

    <main class="shell reveal">
      <section class="card">
        <p class="kicker">GM / Admin</p>
        <h1>Control Center</h1>
        <p class="subtitle">Manage accounts and inspect online players.</p>

        <% if (flash) { %>
        <div class="flash <%= flash.type %>"><%= flash.message %></div>
        <% } %>

        <div class="divider"><h2>Account Lookup</h2></div>

        <form class="inline-form" method="get" action="/admin">
          <input name="q" value="<%= searchQuery %>" placeholder="username or account id" />
          <button class="btn btn-primary" type="submit">Search</button>
        </form>

        <% if (lookedUpAccounts.length === 0 && searchQuery) { %>
        <div class="empty">No account matched your search.</div>
        <% } %>

        <% lookedUpAccounts.forEach((account) => { %>
        <article class="admin-card">
          <header>
            <h3><%= account.username %> (#<%= account.id %>)</h3>
            <span class="pill <%= account.online ? 'up' : 'down' %>">
              <%= account.online ? 'Online' : 'Offline' %>
            </span>
          </header>
          <p>
            GM Level: <strong><%= account.gmlevel %></strong> &nbsp;&middot;&nbsp;
            Locked: <strong><%= account.locked ? 'Yes' : 'No' %></strong> &nbsp;&middot;&nbsp;
            Banned: <strong><%= account.activeBan ? 'Yes' : 'No' %></strong>
          </p>
          <small>
            Joined: <%= account.joindate || '-' %> &nbsp;&middot;&nbsp; Last login: <%= account.last_login || '-' %>
          </small>

          <div class="admin-actions-grid">
            <form method="post" action="/admin/set-gm-level" class="admin-action">
              <input type="hidden" name="account" value="<%= account.id %>" />
              <label>
                Set GM Level (0-3)
                <input type="number" name="gmlevel" min="0" max="3" value="<%= account.gmlevel %>" required />
              </label>
              <label>
                Realm ID
                <input type="number" name="realmId" value="-1" required />
              </label>
              <button class="btn btn-primary" type="submit">Save GM</button>
            </form>

            <form method="post" action="/admin/ban" class="admin-action">
              <input type="hidden" name="account" value="<%= account.id %>" />
              <label>
                Ban Minutes
                <input type="number" name="minutes" min="1" value="60" required />
              </label>
              <label>
                Reason
                <input name="reason" maxlength="255" value="Portal moderation" />
              </label>
              <button class="btn btn-danger" type="submit">Ban Account</button>
            </form>

            <form method="post" action="/admin/unban" class="admin-action">
              <input type="hidden" name="account" value="<%= account.id %>" />
              <p>Remove all active bans for this account.</p>
              <button class="btn btn-primary" type="submit">Unban</button>
            </form>

            <form method="post" action="/admin/toggle-lock" class="admin-action">
              <input type="hidden" name="account" value="<%= account.id %>" />
              <input type="hidden" name="locked" value="<%= account.locked ? '0' : '1' %>" />
              <p><%= account.locked ? 'Unlock this account' : 'Lock this account' %></p>
              <button class="btn btn-ghost" type="submit">
                <%= account.locked ? 'Unlock' : 'Lock' %>
              </button>
            </form>
          </div>
        </article>
        <% }) %>

        <div class="divider"><h2>Online Players</h2></div>

        <% if (onlinePlayers.length === 0) { %>
        <div class="empty">No players are currently online.</div>
        <% } else { %>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Character</th>
                <th>Level</th>
                <th>Race / Class</th>
                <th>Account</th>
                <th>Map / Zone</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <% onlinePlayers.forEach((player) => { %>
              <tr>
                <td><%= player.name %> (#<%= player.guid %>)</td>
                <td><%= player.level %></td>
                <td><%= player.race %> <%= player.class %></td>
                <td><%= player.accountName %> (#<%= player.account %>)</td>
                <td><%= player.map %> / <%= player.zone %></td>
                <td><a class="btn btn-ghost" href="/characters/<%= player.guid %>">View</a></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>

        <div class="divider"><h2>Audit Log <span style="font-size:0.65rem;letter-spacing:0.14em;color:var(--text-dim)">(last 50)</span></h2></div>

        <% if (auditLogs.length === 0) { %>
        <div class="empty">No admin actions have been recorded yet.</div>
        <% } else { %>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>Time</th>
                <th>Actor</th>
                <th>Action</th>
                <th>Target</th>
                <th>Details</th>
              </tr>
            </thead>
            <tbody>
              <% auditLogs.forEach((entry) => { %>
              <tr>
                <td class="nowrap"><%= new Date(entry.ts).toISOString().replace('T',' ').slice(0,19) %> UTC</td>
                <td><%= entry.actor_user %></td>
                <td><code><%= entry.action %></code></td>
                <td><%= entry.target_user || '-' %></td>
                <td><small><%= entry.details || '' %></small></td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } %>

        <div class="divider"><h2>News Management</h2></div>

        <form method="post" action="/admin/news/post" class="news-compose">
          <label>
            Title
            <input name="title" maxlength="200" placeholder="Announcement title&hellip;" required />
          </label>
          <label>
            Body
            <textarea name="body" placeholder="Post content&hellip;" required></textarea>
          </label>
          <div>
            <button class="btn btn-primary" type="submit">Publish Post</button>
          </div>
        </form>

        <% if (newsItems.length > 0) { %>
        <div style="margin-top:1.2rem">
          <% newsItems.forEach((post) => { %>
          <div class="news-item-row">
            <div class="news-item-meta">
              <strong><%= post.title %></strong>
              <small><%= new Date(post.created_at).toISOString().replace('T',' ').slice(0,16) %> UTC &mdash; by <%= post.author %></small>
            </div>
            <form method="post" action="/admin/news/delete">
              <input type="hidden" name="id" value="<%= post.id %>" />
              <button class="btn btn-danger" type="submit" style="font-size:0.78rem;padding:0.35rem 0.7rem">Delete</button>
            </form>
          </div>
          <% }) %>
        </div>
        <% } else { %>
        <div class="empty" style="margin-top:1rem">No news posts yet.</div>
        <% } %>
      </section>
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">
          Bobek Industries
          <span class="footer-patch">WotLK 3.3.5a</span>
        </div>
        <p class="footer-legal">Not affiliated with Blizzard Entertainment. World of Warcraft&trade; is a registered trademark of Blizzard Entertainment, Inc.</p>
      </div>
    </footer>
  </body>
</html>
